
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isExistingDoc() {
      return resource != null;
    }
    function isTeacher() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_teachers/$(request.auth.uid));
    }
    function isSupervisor() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_supervisor/$(request.auth.uid));
    }
    function isPropertyCustodian() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_property_custodian/$(request.auth.uid));
    }
    function getSupervisorAssignedDept() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.assignedDepartmentId;
    }


    // --------------------------------------------------------------------------------
    // User Profile Rules
    // --------------------------------------------------------------------------------
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSupervisor());
      allow list: if isSupervisor();
      allow create: if (isSignedIn() && request.auth.uid == userId && request.resource.data.id == userId) || isSupervisor();
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isSupervisor();
      allow delete: if isSupervisor();
    }

    // --------------------------------------------------------------------------------
    // Activity Log Rules
    // --------------------------------------------------------------------------------
    match /activity_logs/{logId} {
        allow list, get: if isSupervisor();
        allow create: if isSignedIn();
    }

    // --------------------------------------------------------------------------------
    // Role-Based Access Control (RBAC) Rules
    // --------------------------------------------------------------------------------
    match /roles_teachers/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, delete: if isSupervisor();
      allow update: if false;
    }
    match /roles_supervisor/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, delete: if isSupervisor();
      allow update: if false;
    }
    match /roles_property_custodian/{userId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create, delete: if isSupervisor();
        allow update: if false;
    }
    
    // --------------------------------------------------------------------------------
    // Facility Management Rules
    // --------------------------------------------------------------------------------
    match /departments/{departmentId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSupervisor();
    }
    match /channels/{channelId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSupervisor();
    }

     // --------------------------------------------------------------------------------
    // Teacher Access Request Rules
    // --------------------------------------------------------------------------------
    match /channel_access_requests/{requestId} {
        allow create: if isTeacher() && isOwner(request.resource.data.teacherId);
        allow list, get: if isOwner(resource.data.teacherId) || isSupervisor();
        allow update: if isSupervisor() || (isTeacher() && isOwner(resource.data.teacherId));
        allow delete: if isOwner(resource.data.teacherId);
    }

    // --------------------------------------------------------------------------------
    // Student Department Access Request Rules
    // --------------------------------------------------------------------------------
    match /student_department_access_requests/{requestId} {
        allow create: if isOwner(request.resource.data.studentId);
        allow get: if isOwner(resource.data.studentId) || isSupervisor();
        allow list: if isSignedIn();
        allow update: if isSupervisor();
        allow delete: if isOwner(resource.data.studentId);
    }


    // --------------------------------------------------------------------------------
    // Inventory Rules
    // --------------------------------------------------------------------------------
     match /inventory_items/{itemId} {
        allow get, list: if isSignedIn();
        allow create: if isPropertyCustodian();
        allow delete, update: if isSupervisor();
      }

    // --------------------------------------------------------------------------------
    // Borrowing Transaction Rules
    // --------------------------------------------------------------------------------
    match /borrowing_transactions/{transactionId} {
      allow get: if isOwner(resource.data.borrowerUserId) || isSupervisor();
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data.borrowerUserId);
      allow update, delete: if isOwner(resource.data.borrowerUserId) || isSupervisor();
    }
  }
}
