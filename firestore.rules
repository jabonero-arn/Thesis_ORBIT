
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isSupervisor() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_supervisor/$(request.auth.uid))
      );
    }
    function isTeacher() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_teachers/$(request.auth.uid));
    }
    function isPropertyCustodian() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_property_custodian/$(request.auth.uid));
    }

    // --------------------------------------------------------------------------------
    // User Profile Rules
    // --------------------------------------------------------------------------------
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSupervisor());
      allow list: if isSupervisor();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isSupervisor();
      allow delete: if isSupervisor();
    }

    // --------------------------------------------------------------------------------
    // Facility & Inventory Rules (Public for Authenticated Users)
    // --------------------------------------------------------------------------------
    match /departments/{departmentId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSupervisor();
    }
    match /channels/{channelId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSupervisor();
    }
    match /inventory_items/{itemId} {
      allow get, list: if isSignedIn();
      allow create: if isPropertyCustodian() || isSupervisor();
      allow update, delete: if isSupervisor() || isPropertyCustodian();
    }

    // --------------------------------------------------------------------------------
    // Activity Log Rules
    // --------------------------------------------------------------------------------
    match /activity_logs/{logId} {
        allow get, list: if isSupervisor();
        allow create: if isSignedIn();
    }

    // --------------------------------------------------------------------------------
    // Role-Based Access Control (RBAC) Rules
    // --------------------------------------------------------------------------------
    match /roles_teachers/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, delete: if isSupervisor();
    }
    match /roles_supervisor/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, delete: if isSupervisor();
    }
    match /roles_head_supervisor/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, delete: if isSupervisor();
    }
    match /roles_property_custodian/{userId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create, delete: if isSupervisor();
    }
    
     // --------------------------------------------------------------------------------
    // Access Requests Rules
    // --------------------------------------------------------------------------------
    match /channel_access_requests/{requestId} {
        allow create: if isTeacher();
        allow get, list: if isSignedIn(); // Gated by logic in dashboard
        allow update: if isSupervisor() || (isTeacher() && resource.data.teacherId == request.auth.uid);
        allow delete: if isSupervisor() || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }

    match /student_department_access_requests/{requestId} {
        allow create: if isSignedIn();
        allow get, list: if isSignedIn();
        allow update: if isSupervisor();
        allow delete: if isSupervisor() || (resource.data.studentId == request.auth.uid);
    }

    // --------------------------------------------------------------------------------
    // Borrowing Transaction Rules
    // --------------------------------------------------------------------------------
    match /borrowing_transactions/{transactionId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      
      // Update rules for Borrowing Transactions:
      // 1. Supervisors can update any transaction.
      // 2. Students can update their own transactions (e.g., for cancellations).
      // 3. Teachers can approve/deny transactions specifically assigned to them (teacherId matches UID).
      // Redploy Trigger: Verification of field name 'teacherId'.
      allow update, delete: if isSupervisor() 
        || resource.data.borrowerUserId == request.auth.uid
        || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }
  }
}
