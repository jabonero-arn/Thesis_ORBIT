
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------------------
    // Helper Functions - v2.1.0 (Ultimate Resiliency & Efficiency)
    // --------------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Explicit Assignment Check - High Priority
    function isAssignedToTransaction(data) {
      let uid = request.auth.uid;
      return isSignedIn() && (
        data.get('teacherId', '') == uid ||
        data.get('assignedTeacherId', '') == uid ||
        data.get('requestedTeacherId', '') == uid ||
        data.get('approvingTeacherId', '') == uid ||
        data.get('teacherUid', '') == uid
      );
    }

    // Defensive Supervisor check
    function isSupervisor() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_supervisor/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_head_supervisor/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in ['Supervisor', 'Head Supervisor'])
      );
    }

    // Defensive Teacher check
    function isTeacher() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_teachers/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'Teacher')
      );
    }

    // Defensive Property Custodian check
    function isPropertyCustodian() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_property_custodian/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'Property Custodian')
      );
    }

    // Defensive Staff check
    function isStaff() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_staff/$(request.auth.uid)) ||
        isPropertyCustodian() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'Staff')
      );
    }

    // --------------------------------------------------------------------------------
    // User Profile Rules
    // --------------------------------------------------------------------------------
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSupervisor());
      allow list: if isSupervisor();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isSupervisor();
      allow delete: if isSupervisor();
    }

    // --------------------------------------------------------------------------------
    // Facility & Inventory Rules
    // --------------------------------------------------------------------------------
    match /departments/{departmentId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSupervisor();
    }
    match /channels/{channelId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSupervisor();
    }
    match /inventory_items/{itemId} {
      allow get, list: if isSignedIn();
      allow create: if isPropertyCustodian() || isSupervisor();
      allow update, delete: if isSupervisor() || isPropertyCustodian() || isStaff();
    }

    // --------------------------------------------------------------------------------
    // Activity Log Rules
    // --------------------------------------------------------------------------------
    match /activity_logs/{logId} {
        allow get, list: if isSupervisor();
        allow create: if isSignedIn();
    }

    // --------------------------------------------------------------------------------
    // Role-Based Access Control (RBAC) Rules
    // --------------------------------------------------------------------------------
    match /roles_teachers/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, delete: if isSupervisor();
    }
    match /roles_supervisor/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, delete: if isSupervisor();
    }
    match /roles_head_supervisor/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, delete: if isSupervisor();
    }
    match /roles_property_custodian/{userId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create, delete: if isSupervisor();
    }
    match /roles_staff/{userId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create, delete: if isSupervisor();
    }
    
     // --------------------------------------------------------------------------------
    // Access Requests Rules
    // --------------------------------------------------------------------------------
    match /channel_access_requests/{requestId} {
        allow create: if isTeacher();
        allow get, list: if isSignedIn();
        allow update: if isSupervisor() || (isTeacher() && resource.data.teacherId == request.auth.uid);
        allow delete: if isSupervisor() || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }

    match /student_department_access_requests/{requestId} {
        allow create: if isSignedIn();
        allow get, list: if isSignedIn();
        allow update: if isSupervisor() || isStaff();
        allow delete: if isSupervisor() || (resource.data.studentId == request.auth.uid);
    }

    // --------------------------------------------------------------------------------
    // Borrowing Transaction Rules - v2.1.0 (Refined)
    // --------------------------------------------------------------------------------
    match /borrowing_transactions/{transactionId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      
      // Update rules: Prioritize Assignment for speed and reliability
      allow update: if isSignedIn() && (
        isAssignedToTransaction(resource.data) ||
        isSupervisor() || 
        isStaff() ||
        (isTeacher() && resource.data.get('status', 'N/A') in ['Pending', 'pending']) ||
        (isOwner(resource.data.get('borrowerUserId', '')) && resource.data.get('status', 'N/A') in ['Pending', 'pending'])
      );
      
      allow delete: if isSupervisor() 
        || resource.data.get('borrowerUserId', 'N/A') == request.auth.uid
        || isAssignedToTransaction(resource.data);
    }
  }
}
