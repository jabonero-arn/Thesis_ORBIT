/**
 * # Firestore Security Rules: LabFlow Prototyping
 *
 * ## Core Philosophy
 * This ruleset enforces a strict role-based access control (RBAC) model. A user's permissions
 * are determined by the existence of a document in dedicated role collections (`/roles_teachers`,
 * `/roles_staff`, etc.), not by a field in their public user profile. This provides a highly
 * secure and performant way to manage authorization. The default security posture is to deny
 * all access unless explicitly granted.
 *
 * ## Data Structure
 * - `/users/{userId}`: Contains non-sensitive, public-facing user information.
 * - `/roles_*` collections: These are 'flag' collections. The mere existence of a
 *   document here grants the user the corresponding role.
 * - `/inventory_items/{itemId}`: A flat collection of all inventory items.
 * - `/one_time_passwords/{otpId}`: Short-lived codes generated by Teachers to unlock specific items.
 * - `/borrowing_transactions/{transactionId}`: A flat, top-level collection of all borrowing records.
 *
 * ## Key Security Decisions
 * - **Role Management**: User roles are determined by `exists()` checks on the `/roles_*` collections.
 *   Admins can manage these role flags, but other users cannot modify their own roles.
 * - **User Privacy & Admin Access**: Admins can list and view all user profiles for management
 *   purposes. Regular users can only access their own `/users/{userId}` document.
 * - **Ownership Model**: Students can only create and manage their own `/borrowing_transactions`.
 * - **Staff/Admin Supremacy**: Users with 'Staff' or 'Admin' roles have broad read/write access
 *   across inventory and transactions for administrative purposes.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isExistingDoc() {
      return resource != null;
    }
    function isTeacher() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_teachers/$(request.auth.uid));
    }
    function isStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_staff/$(request.auth.uid));
    }
    function isSupervisor() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_supervisor/$(request.auth.uid));
    }
     function isPrimaryCustodian() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_primary_custodian/$(request.auth.uid));
    }


    // --------------------------------------------------------------------------------
    // User Profile Rules
    // --------------------------------------------------------------------------------
    match /users/{userId} {
      allow get: if isOwner(userId) || isPrimaryCustodian();
      allow list: if isPrimaryCustodian();
      allow create: if (isOwner(userId) && request.resource.data.id == userId) || isPrimaryCustodian();
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isPrimaryCustodian();
      allow delete: if isPrimaryCustodian();
    }

    // --------------------------------------------------------------------------------
    // Role-Based Access Control (RBAC) Rules
    // --------------------------------------------------------------------------------
    match /roles_teachers/{userId} {
      allow read: if false; // No client-side reads
      allow create, delete: if isPrimaryCustodian();
      allow update: if false;
    }
    match /roles_staff/{userId} {
      allow read: if false;
      allow create, delete: if isPrimaryCustodian();
      allow update: if false;
    }
    match /roles_supervisor/{userId} {
      allow read: if false;
      allow create, delete: if isPrimaryCustodian();
      allow update: if false;
    }
    match /roles_primary_custodian/{userId} {
        allow read: if false;
        allow create, delete: if isPrimaryCustodian();
        allow update: if false;
    }

    // --------------------------------------------------------------------------------
    // Inventory Rules
    // --------------------------------------------------------------------------------
     match /inventory_items/{itemId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isStaff() || isSupervisor() || isPrimaryCustodian();
      }

    // --------------------------------------------------------------------------------
    // One-Time Password Rules
    // --------------------------------------------------------------------------------
    match /one_time_passwords/{otpId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isTeacher() && isOwner(request.resource.data.generatedByUserId);
      allow update: if false;
      allow delete: if (isOwner(resource.data.generatedByUserId) && isExistingDoc()) || (isStaff() && isExistingDoc());
    }

    // --------------------------------------------------------------------------------
    // Borrowing Transaction Rules
    // --------------------------------------------------------------------------------
    match /borrowing_transactions/{transactionId} {
      allow get: if isStaff() || isOwner(resource.data.borrowerUserId) || isPrimaryCustodian() || isSupervisor();
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data.borrowerUserId);
      allow update: if (isStaff() && isExistingDoc()) || (isOwner(resource.data.borrowerUserId) && isExistingDoc()) || isPrimaryCustodian() || isSupervisor();
      allow delete: if isStaff() && isExistingDoc() || isPrimaryCustodian() || isSupervisor();
    }
  }
}
