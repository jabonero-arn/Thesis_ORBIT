/**
 * # Firestore Security Rules: LabFlow Prototyping
 *
 * ## Core Philosophy
 * This ruleset enforces a strict role-based access control (RBAC) model. A user's permissions
 * are determined by the existence of a document in dedicated role collections (`/roles_teachers`
 * or `/roles_staff`), not by a field in their public user profile. This provides a highly
 * secure and performant way to manage authorization. The default security posture is to deny
 * all access unless explicitly granted.
 *
 * ## Data Structure
 * - `/users/{userId}`: Contains non-sensitive, public-facing user information.
 * - `/roles_teachers/{userId}` & `/roles_staff/{userId}`: These are 'flag' collections. The mere existence of a
 *   document here grants the user the corresponding role. Client-side writes are forbidden.
 * - `/inventory_items/{itemId}`: A flat collection of all inventory items.
 * - `/one_time_passwords/{otpId}`: Short-lived codes generated by Teachers to unlock specific items.
 * - `/borrowing_transactions/{transactionId}`: A flat, top-level collection of all borrowing records.
 *   This structure enables efficient querying for both Staff (all records) and Students (their own records).
 *
 * ## Key Security Decisions
 * - **Role Management**: User roles are determined by `exists()` checks on the `/roles_*` collections. This is a
 *   fast, secure, and non-billable read operation within rules. Clients cannot modify their own roles.
 * - **User Privacy**: Listing all users is disabled to protect user privacy. Users can only access their own
 *   `/users/{userId}` document.
 * - **Ownership Model**: Students can only create and manage their own `/borrowing_transactions`. Teachers can only
 *   create and manage the `/one_time_passwords` they generate.
 * - **Staff Supremacy**: Users with the 'Staff' role have broad read/write access across inventory and
 *   transactions for administrative purposes.
 *
 * ## Denormalization for Authorization
 * To ensure fast and simple rules, authorization data is denormalized directly onto the documents
 * being secured. For example, `borrowing_transactions` contain a `borrowerUserId`, and `one_time_passwords`
 * contain a `generatedByUserId`. This avoids slow, costly, and sometimes impossible `get()` calls to other
 * documents during rule evaluation.
 *
 * ## Structural Segregation
 * The `/borrowing_transactions` collection is intentionally a top-level collection rather than a subcollection
 * under users. This allows Staff to perform efficient list operations across all transactions in the system,
 * a critical requirement for administrative oversight, without needing complex and slow collection group queries.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId,
     * establishing document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the document being operated on already exists in Firestore.
     * Crucial for protecting against writes on non-existent paths.
     */
    function isExistingDoc() {
      return resource != null;
    }

    /**
     * Checks if the user has the 'Teacher' role by verifying the existence
     * of a corresponding document in the roles collection. This is a fast,
     * non-billable check within security rules.
     */
    function isTeacher() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_teachers/$(request.auth.uid));
    }

    /**
     * Checks if the user has the 'Staff' role by verifying the existence
     * of a corresponding document in the roles collection.
     */
    function isStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_staff/$(request.auth.uid));
    }

    // --------------------------------------------------------------------------------
    // User Profile Rules
    // --------------------------------------------------------------------------------

    /**
     * @description Manages a user's own profile document.
     * @path        /users/{userId}
     * @allow       (create, get, update) A user can manage their own profile.
     * @deny        (list, delete) A user cannot read another user's profile, list all users, or delete their own profile.
     * @principle   Restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && isExistingDoc();
      allow delete: if false;
    }

    // --------------------------------------------------------------------------------
    // Role-Based Access Control (RBAC) Rules
    // --------------------------------------------------------------------------------

    /**
     * @description Secures the Teacher role collection. These are flags for authorization, not data.
     * @path        /roles_teachers/{userId}
     * @allow       (none) No client-side operations are permitted.
     * @deny        (all) Roles must be managed by a trusted server environment.
     * @principle   Prevents privilege escalation by disallowing client-side role modification.
     */
    match /roles_teachers/{userId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Secures the Staff role collection. These are flags for authorization, not data.
     * @path        /roles_staff/{userId}
     * @allow       (none) No client-side operations are permitted.
     * @deny        (all) Roles must be managed by a trusted server environment.
     * @principle   Prevents privilege escalation by disallowing client-side role modification.
     */
    match /roles_staff/{userId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // --------------------------------------------------------------------------------
    // Inventory Rules
    // --------------------------------------------------------------------------------

    /**
     * @description Defines access for inventory items. Readable by all, managed by Staff.
     * @path        /inventory_items/{itemId}
     * @allow       (get, list) Any authenticated user can view inventory items.
     * @allow       (create, update, delete) A user with the 'Staff' role can manage inventory.
     * @deny        (create) A student trying to add an item to inventory.
     * @principle   Provides public read access with role-restricted writes.
     */
     match /inventory_items/{itemId} {
        allow get, list: if isSignedIn();
        allow create: if isStaff();
        allow update: if isStaff() && isExistingDoc();
        allow delete: if isStaff() && isExistingDoc();
      }

    // --------------------------------------------------------------------------------
    // One-Time Password Rules
    // --------------------------------------------------------------------------------

    /**
     * @description Manages One-Time Passwords (OTPs) generated for locked items.
     * @path        /one_time_passwords/{otpId}
     * @allow       (create) A user with the 'Teacher' role can generate an OTP.
     * @allow       (get) Any authenticated user can fetch a specific OTP (needed for borrowing flow).
     * @allow       (delete) The generating Teacher or any Staff member can delete an OTP.
     * @deny        (list) Listing all active OTPs is forbidden to prevent scraping.
     * @deny        (update) OTPs are immutable and cannot be changed once created.
     * @principle   Enforces document ownership for creation and deletion, with role-based permissions.
     */
    match /one_time_passwords/{otpId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isTeacher() && isOwner(request.resource.data.generatedByUserId);
      allow update: if false;
      allow delete: if (isOwner(resource.data.generatedByUserId) && isExistingDoc()) || (isStaff() && isExistingDoc());
    }

    // --------------------------------------------------------------------------------
    // Borrowing Transaction Rules
    // --------------------------------------------------------------------------------

    /**
     * @description Governs access to borrowing transaction records.
     * @path        /borrowing_transactions/{transactionId}
     * @allow       (create) A student can create a transaction for themselves.
     * @allow       (get, update) The borrowing student or any Staff member can access/update the transaction.
     * @allow       (delete) Only Staff can delete transaction records.
     * @deny        (get) A student cannot read another student's transaction history.
     * @principle   Uses denormalized ownership fields (`borrowerUserId`) for fine-grained access control.
     */
    match /borrowing_transactions/{transactionId} {
      allow get: if isStaff() || isOwner(resource.data.borrowerUserId);
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data.borrowerUserId);
      allow update: if (isStaff() && isExistingDoc()) || (isOwner(resource.data.borrowerUserId) && isExistingDoc());
      allow delete: if isStaff() && isExistingDoc();
    }
  }
}
