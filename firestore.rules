
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Robust Supervisor check: Uses dedicated role collections
    function isSupervisor() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_supervisor/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_head_supervisor/$(request.auth.uid))
      );
    }

    // robust Teacher check: Uses dedicated role collection
    function isTeacher() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_teachers/$(request.auth.uid));
    }

    function isPropertyCustodian() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_property_custodian/$(request.auth.uid));
    }

    function isStaff() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_staff/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_property_custodian/$(request.auth.uid))
      );
    }

    // --------------------------------------------------------------------------------
    // User Profile Rules
    // --------------------------------------------------------------------------------
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSupervisor());
      allow list: if isSupervisor();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isSupervisor();
      allow delete: if isSupervisor();
    }

    // --------------------------------------------------------------------------------
    // Facility & Inventory Rules
    // --------------------------------------------------------------------------------
    match /departments/{departmentId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSupervisor();
    }
    match /channels/{channelId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSupervisor();
    }
    match /inventory_items/{itemId} {
      allow get, list: if isSignedIn();
      allow create: if isPropertyCustodian() || isSupervisor();
      allow update, delete: if isSupervisor() || isPropertyCustodian() || isStaff();
    }

    // --------------------------------------------------------------------------------
    // Activity Log Rules
    // --------------------------------------------------------------------------------
    match /activity_logs/{logId} {
        allow get, list: if isSupervisor();
        allow create: if isSignedIn();
    }

    // --------------------------------------------------------------------------------
    // Role-Based Access Control (RBAC) Rules
    // --------------------------------------------------------------------------------
    match /roles_teachers/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, delete: if isSupervisor();
    }
    match /roles_supervisor/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, delete: if isSupervisor();
    }
    match /roles_head_supervisor/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, delete: if isSupervisor();
    }
    match /roles_property_custodian/{userId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create, delete: if isSupervisor();
    }
    match /roles_staff/{userId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create, delete: if isSupervisor();
    }
    
     // --------------------------------------------------------------------------------
    // Access Requests Rules
    // --------------------------------------------------------------------------------
    match /channel_access_requests/{requestId} {
        allow create: if isTeacher();
        allow get, list: if isSignedIn();
        allow update: if isSupervisor() || (isTeacher() && resource.data.teacherId == request.auth.uid);
        allow delete: if isSupervisor() || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }

    match /student_department_access_requests/{requestId} {
        allow create: if isSignedIn();
        allow get, list: if isSignedIn();
        allow update: if isSupervisor() || isStaff();
        allow delete: if isSupervisor() || (resource.data.studentId == request.auth.uid);
    }

    // --------------------------------------------------------------------------------
    // Borrowing Transaction Rules
    // --------------------------------------------------------------------------------
    match /borrowing_transactions/{transactionId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      
      // Update rules: RESILIENT TEACHER AUTHORIZATION - v1.4.0
      // Allows the assigned teacher OR supervisor/staff OR borrower to update
      allow update: if isSignedIn() && (
        isSupervisor() || 
        isStaff() ||
        request.auth.uid == resource.data.get('teacherId', '') ||
        request.auth.uid == resource.data.get('assignedTeacherId', '') ||
        request.auth.uid == resource.data.get('approvingTeacherId', '') ||
        request.auth.uid == resource.data.get('teacherUid', '') ||
        request.auth.uid == resource.data.get('borrowerUserId', '')
      );
      
      allow delete: if isSupervisor() 
        || resource.data.get('borrowerUserId', '') == request.auth.uid
        || resource.data.get('teacherId', '') == request.auth.uid;
    }
  }
}
