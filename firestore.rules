rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isExistingDoc() {
      return resource != null;
    }
    function isTeacher() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_teachers/$(request.auth.uid));
    }
    function isStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_staff/$(request.auth.uid));
    }
    function isSupervisor() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_supervisor/$(request.auth.uid));
    }
     function isHeadSupervisor() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_head_supervisor/$(request.auth.uid));
    }
    function isPropertyCustodian() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_property_custodian/$(request.auth.uid));
    }
    function getStaffAssignedDept() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.assignedDepartmentId;
    }


    // --------------------------------------------------------------------------------
    // User Profile Rules
    // --------------------------------------------------------------------------------
    match /users/{userId} {
      allow get: if isOwner(userId) || isHeadSupervisor();
      allow list: if isHeadSupervisor();
      allow create: if (isOwner(userId) && request.resource.data.id == userId) || isHeadSupervisor();
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isHeadSupervisor();
      allow delete: if isHeadSupervisor();
    }

    // --------------------------------------------------------------------------------
    // Activity Log Rules
    // --------------------------------------------------------------------------------
    match /activity_logs/{logId} {
        allow list, get: if isHeadSupervisor();
        allow create: if isSignedIn();
    }

    // --------------------------------------------------------------------------------
    // Role-Based Access Control (RBAC) Rules
    // --------------------------------------------------------------------------------
    match /roles_teachers/{userId} {
      allow read: if false; // No client-side reads
      allow create, delete: if isHeadSupervisor();
      allow update: if false;
    }
    match /roles_staff/{userId} {
      allow read: if false;
      allow create, delete: if isHeadSupervisor();
      allow update: if false;
    }
    match /roles_supervisor/{userId} {
      allow read: if false;
      allow create, delete: if isHeadSupervisor();
      allow update: if false;
    }
    match /roles_head_supervisor/{userId} {
        allow read: if false;
        allow create, delete: if isHeadSupervisor();
        allow update: if false;
    }
    match /roles_property_custodian/{userId} {
        allow read: if false;
        allow create, delete: if isHeadSupervisor();
        allow update: if false;
    }
    
    // --------------------------------------------------------------------------------
    // Facility Management Rules
    // --------------------------------------------------------------------------------
    match /departments/{departmentId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isHeadSupervisor();
    }
    match /channels/{channelId} {
      allow read: if isSignedIn();
      allow create: if isHeadSupervisor() || (isSupervisor() && request.resource.data.departmentId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.assignedDepartmentId);
      allow update, delete: if isHeadSupervisor() || (isSupervisor() && resource.data.departmentId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.assignedDepartmentId);
    }
     // --------------------------------------------------------------------------------
    // Teacher Access Request Rules
    // --------------------------------------------------------------------------------
    match /channel_access_requests/{requestId} {
        allow create: if isTeacher() && isOwner(request.resource.data.teacherId);
        allow list, get: if isOwner(resource.data.teacherId) || isSupervisor();
        allow update: if (isSupervisor() && request.resource.data.keys().hasOnly(['status'])) || (isTeacher() && isOwner(resource.data.teacherId));
        allow delete: if isOwner(resource.data.teacherId);
    }

    // --------------------------------------------------------------------------------
    // Student Department Access Request Rules
    // --------------------------------------------------------------------------------
    match /student_department_access_requests/{requestId} {
        allow create: if isOwner(request.resource.data.studentId);
        allow get: if isOwner(request.resource.data.studentId) || isStaff();
        allow list: if isSignedIn();
        allow update: if isStaff() && request.resource.data.keys().hasOnly(['status']) && resource.data.departmentId == getStaffAssignedDept();
        allow delete: if isOwner(request.resource.data.studentId);
    }


    // --------------------------------------------------------------------------------
    // Inventory Rules
    // --------------------------------------------------------------------------------
     match /inventory_items/{itemId} {
        allow get, list: if isSignedIn();
        allow create: if isPropertyCustodian();
        allow delete: if isHeadSupervisor() || isSupervisor();
        allow update: if isStaff() || isSupervisor() || isHeadSupervisor();
      }

    // --------------------------------------------------------------------------------
    // Borrowing Transaction Rules
    // --------------------------------------------------------------------------------
    match /borrowing_transactions/{transactionId} {
      allow get: if isStaff() || isOwner(resource.data.borrowerUserId) || isHeadSupervisor() || isSupervisor();
      allow list: if isSignedIn();
      allow create: if isOwner(request.resource.data.borrowerUserId);
      allow update: if (isStaff() && isExistingDoc()) || (isOwner(resource.data.borrowerUserId) && isExistingDoc()) || isHeadSupervisor() || isSupervisor();
      allow delete: if isStaff() && isExistingDoc() || isHeadSupervisor() || isSupervisor();
    }
  }
}